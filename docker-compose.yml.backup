version: '3.8'
services:
  cowork-app:
    image: cowork-agency:latest
    container_name: cowork-app
    restart: unless-stopped
    networks:
      - traefik_public
    labels:
      - traefik.enable=true
      - traefik.http.routers.cowork-app.rule=Host(`app.somosdex.com`)
      - traefik.http.routers.cowork-app.entrypoints=websecure
      - traefik.http.routers.cowork-app.tls.certresolver=letsencrypt
      - traefik.http.routers.cowork-app-http.rule=Host(`app.somosdex.com`)
      - traefik.http.routers.cowork-app-http.entrypoints=web
      - traefik.http.routers.cowork-app-http.middlewares=redirect-to-https
      - traefik.http.middlewares.redirect-to-https.redirectscheme.scheme=https
      - traefik.http.services.cowork-app.loadbalancer.server.port=3000

networks:
  traefik_public:
    external: true
